# ============================================================
# HOLOS — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (required) — get from https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic (optional) — enables the AI Coach at /coach
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App URL (optional — used for absolute URL generation in emails etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
